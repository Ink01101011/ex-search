{
  "name": "ex-search",
  "version": "0.1.0",
  "description": "Scoring-based fuzzy search with Myers Levenshtein distance and radix/tim sort ranking. Part of the ex-* ecosystem.",
  "keywords": [
    "search",
    "fuzzy-search",
    "fuzzy",
    "levenshtein",
    "levenshtein-distance",
    "myers-algorithm",
    "scoring",
    "ranking",
    "radix-sort",
    "tim-sort",
    "web-worker",
    "typescript",
    "typed",
    "esm",
    "tree-shakeable",
    "zero-dependency",
    "ex-search",
    "exsorted",
    "ex-flow"
  ],
  "homepage": "https://github.com/Ink01101011/ex-search#readme",
  "bugs": {
    "url": "https://github.com/Ink01101011/ex-search/issues"
  },
  "license": "MIT",
  "author": "Ink01101011",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Ink01101011/ex-search.git"
  },
  "type": "commonjs",
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./types": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/types/index.mjs",
      "require": "./dist/types/index.cjs"
    }
  },
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup --config tsup.config.ts",
    "minify": "tsup --config tsup.config.ts --minify",
    "test": "jest",
    "lint": "oxlint . --deny-warnings",
    "lint:fix": "oxlint . --fix",
    "typecheck": "tsc --noEmit",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "prepare": "husky",
    "release:check": "pnpm run lint && pnpm run typecheck && pnpm exec jest --ci",
    "prepublishOnly": "pnpm run release:check && pnpm run minify",
    "dev": "tsx src/examples/branch-search.example.ts"
  },
  "peerDependencies": {
    "ex-flow": "^1.0.4",
    "exsorted": "^1.1.0"
  },
  "peerDependenciesMeta": {
    "ex-flow": {
      "optional": true
    },
    "exsorted": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^25.5.0",
    "ex-flow": "^1.0.4",
    "exsorted": "^1.1.0",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "lint-staged": "^16.4.0",
    "oxlint": "^1.58.0",
    "prettier": "^3.8.1",
    "ts-jest": "^29.4.8",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  },
  "lint-staged": {
    "*.{ts,tsx,js,mjs,cjs,json,md,yml,yaml}": [
      "prettier --write"
    ],
    "*.{ts,tsx,js,mjs,cjs}": [
      "oxlint --fix"
    ]
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@10.24.0"
}
